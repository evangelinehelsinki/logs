_public\":false,\"id\":71,\"public_id\":\"3LLcB4S23QNr\",\"user_id\":1,\"worn_count\":0,\"last_worn\":null,\"image_variants\":null,\"created_at\":\"2026-02-26T17:11:10.718157\",\"updated_at\":\"2026-02-26T19:37:39.078048\"},{\"name\":\"Pinstripe Power Suit with Fitted Turtleneck\",\"description\":\"A sophisticated monochromatic ensemble featuring a charcoal pinstripe blazer and matching trousers paired with a fitted grey turtleneck for a modern business-casual look.\",\"garment_ids\":[376,377,378],\"image_url\":\"/uploads/shared/761eb96d6cbae0df14d427c049a90a6ec53a69e31635038fbc3c2c64ae609052.webp\",\"image_path\":\"shared/761eb96d6cbae0df14d427c049a90a6ec53a69e31635038fbc3c2c64ae609052.webp\",\"occasion\":\"Office meetings, business lunches, professional events\",\"season\":\"fall\",\"formality\":\"business-casual\",\"style_vibe\":\"minimalist\",\"coverage\":\"conservative\",\"user_rating\":null,\"style_score\":75.0,\"ai_notes\":\"The monochromatic palette creates visual cohesion while the pinstripe pattern adds classic menswear-inspired tailoring. The fitted turtleneck modernizes the traditional suit look.\",\"is_owned\":false,\"is_public\":false,\"id\":70,\"public_id\":\"AJEbzkVxnK2C\",\"user_id\":1,\"worn_count\":0,\"last_worn\":null,\"image_variants\":null,\"created_at\":\"2026-02-26T17:11:10.711990\",\"updated_at\":\"2026-02-26T19:37:33.882157\"},{\"name\":\"Gothic All-Black Ensemble\",\"description\":\"A dramatic head-to-toe black outfit featuring layered gothic pieces with leather accents and platform boots. The look combines dark academia and gothic fashion elements with strategic layering and accessories.\",\"garment_ids\":[370,371,372,373,374,375],\"image_url\":\"/uploads/shared/672a28057a36effc4932974e215ffb5bf25201c1f0d7dc620c61ec34e7c8e735.webp\",\"image_path\":\"shared/672a28057a36effc4932974e215ffb5bf25201c1f0d7dc620c61ec34e7c8e735.webp\",\"occasion\":\"Alternative fashion events or creative social gatherings\",\"season\":\"fall\",\"formality\":\"sma